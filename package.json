{
  "name": "@etweisberg/garmin-connect-mcp",
  "version": "0.1.3",
  "description": "MCP server for Garmin Connect — access activities, metrics, and FIT files via Claude Code",
  "type": "module",
  "bin": {
    "garmin-connect-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etweisberg/garmin-connect-mcp.git"
  },
  "homepage": "https://github.com/etweisberg/garmin-connect-mcp#readme",
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx src/test.ts",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "playwright": "^1.52.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "garmin",
    "garmin-connect",
    "mcp",
    "model-context-protocol",
    "fit",
    "fitness",
    "claude"
  ],
  "license": "AGPL-3.0"
}
